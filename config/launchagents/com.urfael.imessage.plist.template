<?xml version="1.0" encoding="UTF-8"?>
<!-- Urfael iMessage bridge — OPT-IN remote access, macOS only. install.sh fills {{HOME}}/{{NODE}} but does NOT load it.
     Enable only after setting IMESSAGE_* in ~/.claude/urfael/bridge.env AND granting the runner Full Disk Access
     (System Settings > Privacy & Security > Full Disk Access) so it can read chat.db. Read SECURITY.md first. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.urfael.imessage</string>
  <key>ProgramArguments</key>
  <array><string>{{NODE}}</string><string>{{REPO}}/app/bridge/imessage-bridge.js</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><dict><key>SuccessfulExit</key><false/></dict>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
  <key>StandardOutPath</key><string>{{HOME}}/.claude/urfael/imessage.out.log</string>
  <key>StandardErrorPath</key><string>{{HOME}}/.claude/urfael/imessage.err.log</string>
</dict></plist>
