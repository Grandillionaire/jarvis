<?xml version="1.0" encoding="UTF-8"?>
<!-- Urfael WhatsApp bridge — OPT-IN remote access. install.sh fills {{HOME}}/{{NODE}} but does NOT load it.
     This is the ONE bridge with an INBOUND webhook: it listens on 127.0.0.1 ONLY (front it with a tunnel) and
     verifies every payload's HMAC + the owner number. Enable only after setting WHATSAPP_* in
     ~/.claude/urfael/bridge.env. Read SECURITY.md first. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.urfael.whatsapp</string>
  <key>ProgramArguments</key>
  <array><string>{{NODE}}</string><string>{{REPO}}/app/bridge/whatsapp-bridge.js</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><dict><key>SuccessfulExit</key><false/></dict>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
  <key>StandardOutPath</key><string>{{HOME}}/.claude/urfael/whatsapp.out.log</string>
  <key>StandardErrorPath</key><string>{{HOME}}/.claude/urfael/whatsapp.err.log</string>
</dict></plist>
