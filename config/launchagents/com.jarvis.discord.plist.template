<?xml version="1.0" encoding="UTF-8"?>
<!-- Jarvis Discord bridge — OPT-IN remote access. install.sh fills {{HOME}}/{{NODE}} but does NOT load it.
     Enable only after setting DISCORD_* in ~/.claude/jarvis/bridge.env (Node 22+). Read SECURITY.md first. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.jarvis.discord</string>
  <key>ProgramArguments</key>
  <array><string>{{NODE}}</string><string>{{HOME}}/jarvis/app/bridge/discord-bridge.js</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><dict><key>SuccessfulExit</key><false/></dict>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
  <key>StandardOutPath</key><string>{{HOME}}/.claude/jarvis/discord.out.log</string>
  <key>StandardErrorPath</key><string>{{HOME}}/.claude/jarvis/discord.err.log</string>
</dict></plist>
